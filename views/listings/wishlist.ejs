<% layout("/layouts/boilerplate") %>

<% if (listings.length === 0) { %>
    <div class="card no-results-card mb-4">
        <div class="card-body text-center">
            <h3 class="card-title mt-4">No Saved Places!</h3>
            <p class="card-text">Start exploring and add your favorite places!</p>
            <a href="/listings" class="btn btn-dark mt-2 mb-4">Explore more</a>
        </div>
    </div>

<% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of listings){ %>
            <div class="col listing-card-wrapper">  
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                            <b><%= listing.title %></b> <br>
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                            </p>
                        </div>
                    </div>
                </a>
                <i class="remove-wishlist fa-solid fa-heart-circle-minus"
                    data-id="<%= listing._id %>"
                    style="color: rgb(220,50,50);">
                </i>
            </div>
        <% } %>
    </div>
<% } %>
