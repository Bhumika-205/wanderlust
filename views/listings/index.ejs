<% layout("/layouts/boilerplate") %>

<link rel="stylesheet" href="css/style.css">


<% if (allListings.length > 0) { %>
    
    <div id="filters">
        <a href="/listings?category=trending<%= search ? `&search=${search}` : '' %>">
                <div class="filter <%= category === 'trending' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </div>
        </a>
        
        <a href="/listings?category=rooms<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'rooms' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </div>
        </a>

        <a href="/listings?category=cities<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'cities' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-city"></i></div>
                <p>Iconic cities</p>
            </div>
        </a>

        <a href="/listings?category=mountains<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'mountains' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </div>
        </a>

        <a href="/listings?category=castles<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'castles' ? 'active-filter' : '' %>">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </div>
        </a>

        <a href="/listings?category=pools<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'pools' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-water-ladder"></i></div>
                <p>Amazing pools</p>
            </div>
        </a>

        <a href="/listings?category=camping<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'camping' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </div>
        </a>

        <a href="/listings?category=farms<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'farms' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-tractor"></i></div>
                <p>Farms</p>
            </div>
        </a>

        <a href="/listings?category=arctic<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'arctic' ? 'active-filter' : '' %>">
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </div>
        </a>

        <a href="/listings?category=luxury<%= search ? `&search=${search}` : '' %>">
            <div class="filter <%= category === 'luxury' ? 'active-filter' : '' %>">
                <div><i class="fa-solid fa-star"></i></div>
                <p>Luxury</p>
            </div>
        </a>

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings){ %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b> <br>
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                            <i class="tax-info"> &nbsp;&nbsp; +18% GST </i>
                        </p>
                    </div>
                </div>
            </a>
            
        <% } %>
    </div>
<% } else { %>
        <div class="card no-results-card">
            <div class="card-body text-center">
                <h3 class="card-title mt-4">No places found</h3>
                <p class="card-text">
                    Looks like this place is not listed on Wanderlust yet.
                </p>
                <a href="/listings" class="btn btn-dark mt-2 mb-4">Explore more</a>
            </div>
        </div>
    <% } %>


<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for(info of taxInfo){
            if(info.style.display != "inline"){
                info.style.display = "inline";
            }else{
                info.style.display = "none";
            }
        }
    })
</script>